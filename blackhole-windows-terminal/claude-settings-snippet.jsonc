// For Claude Code token-driven mode:
// 1) In blackhole_winterminal.hlsl, set: #define SIZE_MODE MODE_TOKENS
// 2) Put blackhole-statusline.js and claude-blackhole-statusline.cmd in C:/Users/YOUR_USER/.claude/
// 3) Add this to C:/Users/YOUR_USER/.claude/settings.json
{
  "statusLine": {
    "type": "command",
    "command": "cmd /d /c C:\\Users\\YOUR_USER\\.claude\\claude-blackhole-statusline.cmd",
    "padding": 0
  }
}
