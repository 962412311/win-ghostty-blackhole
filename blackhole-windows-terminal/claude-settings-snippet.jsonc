// 可手动合并到 C:\Users\YOUR_USER\.claude\settings.json。
// 正常使用时不需要手动复制；运行 `bh claude` 会自动安装这段配置。
{
  "statusLine": {
    "type": "command",
    "command": "p='/mnt/c/Users/YOUR_USER/.claude/claude-blackhole-statusline.sh'; [ -f \"$p\" ] || p='/c/Users/YOUR_USER/.claude/claude-blackhole-statusline.sh'; [ -f \"$p\" ] && bash \"$p\" || true"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "p='/mnt/c/Users/YOUR_USER/.claude/claude-blackhole-statusline.sh'; [ -f \"$p\" ] || p='/c/Users/YOUR_USER/.claude/claude-blackhole-statusline.sh'; [ -f \"$p\" ] && bash \"$p\" || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "p='/mnt/c/Users/YOUR_USER/.claude/claude-blackhole-statusline.sh'; [ -f \"$p\" ] || p='/c/Users/YOUR_USER/.claude/claude-blackhole-statusline.sh'; [ -f \"$p\" ] && bash \"$p\" || true"
          }
        ]
      }
    ]
  }
}
