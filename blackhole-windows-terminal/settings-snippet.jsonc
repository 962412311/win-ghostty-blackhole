// Add this under Windows Terminal settings.json -> profiles -> defaults
// Use Settings -> Open JSON file, then merge this block into the existing JSON.
{
  "profiles": {
    "defaults": {
      "experimental.pixelShaderPath": "C:\\Users\\YOUR_USER\\terminal-shaders\\blackhole_winterminal.hlsl",
      "experimental.retroTerminalEffect": false,
      "opacity": 100,
      "useAcrylic": false
    }
  }
}
