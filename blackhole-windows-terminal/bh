#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
repo="$(cd "$script_dir/.." && pwd -P)"
supervisor="$script_dir/codex-blackhole-supervisor.js"

if ! command -v node >/dev/null 2>&1; then
  echo "node not found" >&2
  exit 127
fi

mode="${1:-codex}"
case "$mode" in
  auto)
    shift || true
    exec node "$script_dir/bh-mode.js" open-codex "$@"
    ;;
  demo|token|tokens|pomodoro|clock|timer|mode|status|current)
    exec node "$script_dir/bh-mode.js" "$mode" --open
    ;;
  codex)
    shift || true
    exec node "$script_dir/bh-mode.js" open-codex "$@"
    ;;
  claude)
    shift || true
    exec node "$script_dir/bh-mode.js" open-claude "$@"
    ;;
  __run_codex)
    shift || true
    ;;
  help|--help|-h)
    cat <<'EOF'
Usage:
  bh demo       Install demo shader and open a new Blackhole tab.
  bh token      Install token shader and open a new Blackhole tab.
  bh pomodoro   Install pomodoro shader and open a new Blackhole tab.
  bh clock      Alias of bh pomodoro.
  bh mode       Print the installed shader path and last requested mode.
  bh            Open a new Blackhole tab running WSL Codex.
  bh claude     Open a new Blackhole tab running Windows Claude Code.
  bh codex      Open a new Blackhole tab running WSL Codex.
EOF
    exit 0
    ;;
  *)
    echo "Unknown mode: $mode" >&2
    echo "Usage: bh [codex]" >&2
    exit 2
    ;;
esac

node "$script_dir/bh-mode.js" token >/dev/null
exec node "$supervisor" "$@"
